# PostgreSQL connection string (required)
# Supabase: Project Settings -> Database -> Connection string -> "Connection pooling" (Transaction mode, port 6543)
# Use the POOLER url (not the direct 5432 one) since Vercel functions are serverless/short-lived.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Auth (required)
# Project Settings -> API -> Project URL / anon public key
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Cloudinary — unsigned upload preset (no API key/secret needed)
# If left unset, /api/upload falls back to these defaults anyway
CLOUDINARY_CLOUD_NAME=erxwiiw1
CLOUDINARY_UPLOAD_PRESET=moderator_preset
